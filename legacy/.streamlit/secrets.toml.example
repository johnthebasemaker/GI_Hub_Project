# ============================================================================
# secrets.toml.example — copy to .streamlit/secrets.toml and fill in.
# .streamlit/secrets.toml is GITIGNORED — your real tokens never get committed.
# Used by the Streamlit app + WhatsApp worker (whatsapp_worker._meta_config /
# _twilio_config). On Streamlit Community Cloud, paste this same content into
# the app's Settings → Secrets box instead of a file.
# ============================================================================

# --- Meta WhatsApp Business Cloud API (the server/production sender) ---------
[meta]
phone_number_id = "PASTE_YOUR_PHONE_NUMBER_ID"     # WhatsApp → API Setup → "Phone number ID"
access_token    = "PASTE_YOUR_PERMANENT_TOKEN"     # System-User permanent token (whatsapp_business_messaging)
api_version     = "v21.0"                          # optional; default is fine

# --- (legacy) Twilio — only if you ever switch back; safe to leave unset -----
# [twilio]
# account_sid = "AC..."
# auth_token  = "..."
# from_number = "whatsapp:+14155238886"
