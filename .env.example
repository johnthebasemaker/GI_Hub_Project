# ============================================================================
# .env.example — copy to .env on the SERVER and fill in. .env is GITIGNORED.
# Used by docker-compose (worker + fastapi services) for the Meta WhatsApp
# sender and the inbound webhook receiver.
# ============================================================================

# --- Meta sender (worker service: whatsapp_worker._meta_config) --------------
META_PHONE_NUMBER_ID=PASTE_YOUR_PHONE_NUMBER_ID
META_ACCESS_TOKEN=PASTE_YOUR_PERMANENT_SYSTEM_USER_TOKEN
# META_API_VERSION=v21.0            # optional

# --- Meta inbound webhook (fastapi service: services/whatsapp_webhook.py) ----
# Verify token: any random string YOU invent; paste the SAME value into Meta's
# webhook "Verify token" field when you register the callback URL.
META_WEBHOOK_VERIFY_TOKEN=PASTE_A_RANDOM_STRING_YOU_CHOOSE
# App Secret: Meta App → Settings → Basic → "App secret". Enables signature checks.
META_APP_SECRET=PASTE_YOUR_META_APP_SECRET
