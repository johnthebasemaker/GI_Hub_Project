<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.gi.streamlit</string>

    <key>WorkingDirectory</key>
    <string>__PROJECT_DIR__</string>

    <!-- Use the wrapper script. Direct exec of `caffeinate <path>` tripped
         exit-126 in some macOS sandbox contexts; the wrapper is a known-good
         workaround. -->
    <key>ProgramArguments</key>
    <array>
        <string>__PROJECT_DIR__/host_setup/scripts/run_streamlit.sh</string>
    </array>

    <key>RunAtLoad</key><true/>
    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key><false/>
        <key>Crashed</key><true/>
    </dict>
    <key>ThrottleInterval</key><integer>10</integer>

    <key>StandardOutPath</key>
    <string>__USER_HOME__/Library/Logs/gi-streamlit.log</string>
    <key>StandardErrorPath</key>
    <string>__USER_HOME__/Library/Logs/gi-streamlit.err</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>__PROJECT_DIR__/.venv/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
        <key>TZ</key>
        <string>Asia/Riyadh</string>
        <key>OLLAMA_HOST</key>
        <string>http://localhost:11434</string>
        <key>OLLAMA_VISION_MODEL</key>
        <string>qwen2.5vl:7b</string>
        <key>GI_SUPPRESS_EMBEDDED_WORKER</key>
        <string>1</string>
    </dict>
</dict>
</plist>
