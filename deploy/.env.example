# ============================================================================
# deploy/.env.example — copy to deploy/.env on the server and fill in.
# `deploy/.env` is gitignored (it holds secrets). NEVER commit the real one.
# ============================================================================

# --- Domain + TLS -----------------------------------------------------------
DOMAIN=erp.example.com
LETSENCRYPT_EMAIL=you@example.com
# Set to 1 for a dry run against Let's Encrypt staging (no rate limits) while
# you verify DNS/firewall; flip back to 0 for the real cert.
LETSENCRYPT_STAGING=0

# --- PostgreSQL (the system of record) --------------------------------------
POSTGRES_USER=gihub
POSTGRES_DB=gihub
# Use a long random password, e.g.  openssl rand -base64 32
POSTGRES_PASSWORD=CHANGE_ME_long_random_password

# --- API auth ---------------------------------------------------------------
# MANDATORY in production: >= 32 chars, random. The API refuses to boot without
# a strong key (GI_ENV=production). Generate one:  openssl rand -hex 32
JWT_SECRET=CHANGE_ME_run_openssl_rand_hex_32

# --- CORS (optional) --------------------------------------------------------
# Leave BLANK for the normal single-origin setup (nginx serves the SPA and
# proxies /api on the same domain → no CORS needed). Only set this (comma-
# separated) if you serve the SPA from a different origin than the API.
CORS_ORIGINS=

# --- WhatsApp Cloud API (Phase 7 — outbound notifications) ------------------
# Leave WHATSAPP_PHONE_NUMBER_ID / WHATSAPP_TOKEN blank to disable outbound
# WhatsApp (messages are still logged to the outbox as 'failed: not configured').
# Use a permanent System User token — never a temporary one.
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TOKEN=
WHATSAPP_API_VERSION=v20.0
# Fallback recipient when a HOD/user has no Phone_Number on file (E.164, no '+').
WHATSAPP_ESCALATION_TO=
# Alert sends use an APPROVED template (deliverable outside the 24h window).
# Create a Utility template with ONE body variable {{1}} and put its name here.
# hello_world (Meta's built-in) works for smoke tests but carries no alert text.
WHATSAPP_TEMPLATE_NAME=alert_notification
WHATSAPP_TEMPLATE_LANG=en

# --- Off-box PostgreSQL backups to S3 (optional) ----------------------------
# The `backup` service dumps nightly to the pg-backups volume regardless. Set
# these to ALSO push each dump to S3 (leave AWS_S3_BUCKET blank = local-only).
# Use a dedicated IAM user scoped to put/list on this bucket only. Retention is
# a bucket lifecycle policy (e.g. 30d → Glacier, 90d → expire), not scripted.
AWS_S3_BUCKET=
AWS_S3_PREFIX=gihub
AWS_DEFAULT_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SSE=AES256
