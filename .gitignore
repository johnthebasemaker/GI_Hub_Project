# Ignore virtual environments
.venv/
venv/
env/

# Ignore databases (Keep your local data local!)
*.db
*.sqlite3
*.db-wal
*.db-shm

# Ignore passwords/secrets
.env
.streamlit/secrets.toml
~$*.xlsx

# Ignore Python cache clutter
__pycache__/
*.pyc

# Attachment store — DB BLOBs are authoritative; disk mirror is local-only.
uploads/

# Phase 6C — CV training artifacts (kept out of git; backed up separately)
models/
data/cv_training/
runs/
yolov8*.pt

# Runtime error logs (developer-facing; not source)
logs/
reports_archive/

# Live operational tracking workbooks (operator-owned, synced via
# tools/excel_sync.py — never commit; archived snapshots in data-archive/
# and legacy/scripts/sme_seed_data/ predate this rule and stay tracked).
*.xlsx
